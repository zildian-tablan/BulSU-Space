# Firebase Admin Configuration - GET THESE FROM FIREBASE CONSOLE
# Download your service account key from Firebase Console > Project Settings > Service Accounts
# Extract the values and set them here
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----"
FIREBASE_PRIVATE_KEY_ID=your-private-key-id

# Firebase Web Config (public values - safe to expose)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=bulsuspace.firebaseapp.com
FIREBASE_STORAGE_BUCKET=bulsuspace.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=842036796128
FIREBASE_APP_ID=1:842036796128:web:8dbd359b0432a8dc218e85

# SendGrid Configuration - GET YOUR API KEY FROM SENDGRID DASHBOARD
SENDGRID_API_KEY=your-sendgrid-api-key-here
EMAIL_FROM=noreply@bulsuspace.web.app

# HuggingFace API Configuration
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# Server Configuration
PORT=5000
NODE_ENV=development

# Security Configuration
SESSION_SECRET=replace_with_random_string_for_session_security
JWT_SECRET=replace_with_random_string_for_jwt_security
CSRF_SECRET=replace_with_random_string_for_csrf_security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# Security Monitoring
ENABLE_SECURITY_LOGGING=true
ENABLE_AUDIT_TRAILS=true
SECURITY_LOG_RETENTION_DAYS=30
MAX_AUDIT_LOGS=10000

# Database Collections
SECURITY_AUDIT_COLLECTION=security_audit_logs
MFA_COLLECTION=mfa_secrets
SECURITY_REPORTS_COLLECTION=security_reports
DEVICE_FINGERPRINTS_COLLECTION=device_fingerprints

# Real-time Monitoring
ENABLE_REALTIME_ALERTS=true
WEBHOOK_SECRET=replace_with_random_string_for_webhook_security
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
EMAIL_ALERT_RECIPIENT=admin@example.com

# IP Geolocation Service
ENABLE_IP_GEOLOCATION=false
IP_GEOLOCATION_API_KEY=your_api_key_here
IP_GEOLOCATION_SERVICE=ipapi

# Device Fingerprinting
ENABLE_DEVICE_FINGERPRINTING=true
MAX_DEVICE_CHANGES_PER_HOUR=3
DEVICE_LOCKOUT_DURATION_MS=1800000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_CREDENTIALS=true

# Email Service Configuration
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-app-password
